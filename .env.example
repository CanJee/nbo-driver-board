# ── App (all environments) ──────────────────────────────────────────────
# Production: set these to the PROD Supabase project (Vercel → Production scope).
# Preview: these are derived automatically at build time from the Supabase–Vercel
# integration (see scripts/vercel-build.sh), so you don't set them for Preview.
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Preview prod→preview data clone (Vercel → Preview scope only) ─────────
# Source project the preview DB is seeded from — use the PROD project's values.
# The service-role key is required so the clone can read all rows (bypasses RLS).
# Consumed by scripts/clone-prod-to-preview.mjs. Never set these in Production scope.
PROD_SUPABASE_URL=https://your-prod-project.supabase.co
PROD_SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key

# Password for the shared dispatcher login on PREVIEW deploys (Preview scope only).
# Auth users aren't part of the data clone, so scripts/seed-preview-user.mjs recreates
# the DISPATCHER_EMAIL account in each preview DB with this password. (Prod passwords
# can't be copied — the Admin API never exposes hashes.)
PREVIEW_DISPATCHER_PASSWORD=a-password-for-preview-logins

# Injected automatically into Preview builds by the Supabase–Vercel integration
# (the clone target): SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
# POSTGRES_URL, POSTGRES_URL_NON_POOLING, … — no need to set these by hand.
